game-of-life.app/Contents/PkgInfo: 
	@test -d game-of-life.app/Contents || mkdir -p game-of-life.app/Contents
	@$(DEL_FILE) game-of-life.app/Contents/PkgInfo
	@echo "APPL????" > game-of-life.app/Contents/PkgInfo
game-of-life.app/Contents/Info.plist: 
	@test -d game-of-life.app/Contents || mkdir -p game-of-life.app/Contents
	@$(DEL_FILE) game-of-life.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - ../../../../Qt/6.11.1/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.game-of-life,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.game-of-life,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,game-of-life,g" -e "s,@LIBRARY@,game-of-life,g" -e "s,\$${EXECUTABLE_NAME},game-of-life,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >game-of-life.app/Contents/Info.plist

all: Makefile \
		game-of-life.app/Contents/PkgInfo \
		game-of-life.app/Contents/Info.plist game-of-life.app/Contents/MacOS/game-of-life

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

